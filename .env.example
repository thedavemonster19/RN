# Copy this file to `.env` and fill in the two values from your Supabase
# project (Dashboard → Project Settings → API). `.env` is gitignored.
#
# These two are SAFE to be public — they get compiled into the game bundle,
# which is exactly how Supabase browser apps work. Row Level Security (see
# supabase/schema.sql) is what protects the data.
#
# NEVER put the `service_role` key in here or anywhere in src/. It bypasses
# Row Level Security entirely, and this repo is public.

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key
